# EmailJS 配置 — QQ 邮箱
# 接收邮箱: 2960772239@qq.com
# 
# 配置步骤（3 步，约 5 分钟）：
#
# 1️⃣ 登录 EmailJS https://dashboard.emailjs.com/admin
#
# 2️⃣ 创建 Email Service（QQ 邮箱 SMTP）
#    左侧菜单 Email Services → Add New Service
#    选择 "SMTP" 或 "Custom SMTP"，填入：
#      Host:       smtp.qq.com
#      Port:       465
#      Use SSL:    ✅
#      Username:   2960772239@qq.com
#      Password:   【QQ邮箱授权码，不是登录密码！】
#    如何获取授权码：QQ邮箱 → 设置 → 账户 → POP3/SMTP服务 → 开启 → 生成授权码
#    创建后会得到 Service ID（如 service_xxxxxx）→ 填入下方
#
# 3️⃣ 创建 Email Template
#    左侧菜单 Email Templates → Create New Template
#    模板内容参考 TEMPLATE_REFERENCE.txt
#    创建后会得到 Template ID（如 template_xxxxxx）→ 填入下方
#    Public Key 在 Account → API Keys 页面

VITE_EMAILJS_SERVICE_ID=YOUR_SERVICE_ID
VITE_EMAILJS_TEMPLATE_ID=YOUR_TEMPLATE_ID
VITE_EMAILJS_PUBLIC_KEY=YOUR_PUBLIC_KEY
